APP_NAME=FeatureVote API
APP_ENV=dev
APP_PORT=8090
API_PREFIX=/api/v1

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGIN_REGEX=^http://192\.168\.[0-9]{1,3}\.[0-9]{1,3}:5173$
FRONTEND_BASE_URL=http://localhost:5173

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=featurevote

FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_REDIRECT_URI=http://localhost:8090/api/v1/auth/feishu/browser/callback
FEISHU_ADMIN_OPEN_IDS=
FEISHU_ADMIN_DEPARTMENT_IDS=
FEISHU_ADMIN_GROUP_IDS=
FEISHU_IMPORT_CHAT_IDS=
FEISHU_IMPORT_INTERVAL_SECONDS=60
FEISHU_IMPORT_BATCH_SIZE=50
FEISHU_IMPORT_DEFAULT_TAGS=飞书导入
FEISHU_IMPORT_MIN_TEXT_CHARS=20
FEISHU_IMPORT_DUPLICATE_THRESHOLD=0.72
FEISHU_IMPORT_NOTIFY_CHAT=true
FEISHU_IMPORT_GROUPING_ENABLED=true
FEISHU_IMPORT_WINDOW_MINUTES=60
FEISHU_IMPORT_MIN_CONFIDENCE=0.65
FEISHU_IMPORT_MAX_MESSAGES_PER_SUMMARY=50
FEISHU_IMPORT_DEBUG_LOGGING=false
FEISHU_IMPORT_DEBUG_LOG_MAX_CHARS=4000

AUTH_COOKIE_NAME=featurevote_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_TOKEN_SECRET=dev-featurevote-change-me
AUTH_TOKEN_TTL_SECONDS=604800

DEEPSEEK_ENABLED=true
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_THINKING=enabled
DEEPSEEK_REASONING_EFFORT=high
DEEPSEEK_TIMEOUT=30
DEEPSEEK_MAX_TEXT_CHARS=12000
DEEPSEEK_MIN_TEXT_CHARS=20

MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=featurevote
# Optional. If empty, backend uses http(s)://MINIO_ENDPOINT/MINIO_BUCKET.
MINIO_PUBLIC_BASE_URL=
MINIO_SECURE=false

TASK_IMAGE_MAX_BYTES=5242880
ATTACHMENT_MAX_BYTES=20971520
